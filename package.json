{
	"name": "vscode-42km-theme",
	"displayName": "42km Theme",
	"description": "A dark VS Code theme inspired by the Marathon game aesthetic",
	"version": "0.0.1",
	"publisher": "andornaut",
	"repository": {
		"type": "git",
		"url": "https://github.com/andornaut/vscode-42km-theme"
	},
	"engines": {
		"vscode": "^1.60.0"
	},
	"categories": [
		"Themes"
	],
	"contributes": {
		"themes": [
			{
				"label": "42km Dark",
				"uiTheme": "vs-dark",
				"path": "./themes/42km-dark-color-theme.json"
			}
		]
	},
	"scripts": {
		"swatches": "rm -rf swatches && mkdir swatches && color-swatches --format png swatches themes/*.json"
	},
	"devDependencies": {
		"@vscode/vsce": "^3.7.1",
		"color-swatches": "github:andornaut/color-swatches-action"
	}
}
