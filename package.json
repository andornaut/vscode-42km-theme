{
    "name": "42km-theme",
    "displayName": "42KM color theme",
    "description": "A Marathon-inspired dark color theme",
    "homepage": "https://github.com/andornaut/vscode-42KM-theme",
    "icon": "icon.png",
    "license": "MIT",
    "publisher": "Andornaut",
    "version": "0.1.2",
    "categories": [
        "Themes"
    ],
    "contributes": {
        "themes": [
            {
                "id": "42KM",
                "label": "42KM",
                "uiTheme": "vs-dark",
                "path": "./themes/42km-theme.json"
            }
        ]
    },
    "engines": {
        "vscode": "^1.60.0"
    },
    "galleryBanner": {
        "color": "#1b1a1d",
        "theme": "dark"
    },
    "keywords": [
        "42KM",
        "dark",
        "green",
        "lime",
        "marathon",
        "solarized dark",
        "solarized"
    ],
    "bugs": {
        "url": "https://github.com/andornaut/vscode-42KM-theme/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/andornaut/vscode-42KM-theme"
    },
    "scripts": {
        "swatches": "rm -rf swatches && mkdir swatches && color-swatches --format png swatches themes/*.json"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.7.1",
        "color-swatches": "github:andornaut/color-swatches-action"
    }
}
